{
  "version": 2,
  "builds": [
    {
      "src": "mangadex_node_proxy.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/mangadex_node_proxy.js"
    },
    {
      "src": "/(.*)",
      "dest": "/public/$1"
    }
  ],
  "functions": {
    "mangadex_node_proxy.js": {
      "maxDuration": 60,
      "memory": 3008
    }
  }
}
